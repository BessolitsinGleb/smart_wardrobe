# Скопируй в .env и заполни

# OpenRouter API (для умных аутфитов)
# Без ключа будет работать случайный взвешенный выбор вещей
# Получить ключ: https://openrouter.ai/keys
OPENROUTER_API_KEY=sk-or-v1-...

# База данных (по умолчанию SQLite — ничего устанавливать не нужно)
DATABASE_URL=sqlite:///./wardrobe.db

# Для PostgreSQL:
# DATABASE_URL=postgresql://user:password@localhost:5432/wardrobe
